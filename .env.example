# Path to the SQLite database file
DB_PATH=./data/someday.db

# The public URL of your instance — required in production
# Must match the domain you're serving from
ORIGIN=http://localhost:3000

# Port to listen on (default: 3000)
# PORT=3000

# Disable open registration. When set, new accounts can't be created via /auth.
# The first account can always be created (bootstrap), so you can leave this on
# from day one and still sign yourself up.
# DISABLE_REGISTRATION=true

# Shared secret for the Postmark inbound-email webhook. Only needed if you're
# enabling email-to-save. Generate with: openssl rand -hex 32
# INBOUND_EMAIL_SECRET=
